OLLAMA_URL=http://localhost:11434
# Model used by live scoring evals (npm run test:live-eval). Override with --model.
# OLLAMA_MODEL=llama3.2
# Chat prompt variant for live evals (default | stricter-no-diagnose). Override with --prompt.
# LOCALLAB_CHAT_PROMPT=default
# Idle timeout in ms while waiting for Ollama tokens; 0 = no limit (default)
OLLAMA_TIMEOUT_MS=0
# Keep 0 for normal use. npm run test:live-eval sets this to 1 (slow; hits local Ollama)
LOCALLAB_LIVE_EVAL=0
# Live-eval per-case timeout in ms (default 900000 / 15m). Override with --timeout-ms.
# LOCALLAB_LIVE_EVAL_TIMEOUT_MS=900000
PORT=3001
